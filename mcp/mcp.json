{
  "_comment": "MCP data ports for Chorus. Wire into Hermes on the runtime box. Secrets via env, never inline. Verify package names against modelcontextprotocol/servers + awesome-mcp before install.",
  "mcpServers": {
    "firecrawl": {
      "command": "npx",
      "args": [
        "-y",
        "firecrawl-mcp"
      ],
      "env": {
        "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}"
      }
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "reddit": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-reddit"
      ],
      "env": {
        "REDDIT_CLIENT_ID": "${REDDIT_CLIENT_ID}",
        "REDDIT_SECRET": "${REDDIT_SECRET}"
      }
    },
    "youtube": {
      "command": "npx",
      "args": [
        "-y",
        "youtube-mcp"
      ],
      "env": {
        "YOUTUBE_API_KEY": "${YOUTUBE_API_KEY}"
      }
    },
    "gcal": {
      "command": "npx",
      "args": [
        "-y",
        "google-calendar-mcp"
      ]
    },
    "supermemory": {
      "command": "npx",
      "args": [
        "-y",
        "supermemory-mcp"
      ],
      "env": {
        "SUPERMEMORY_API_KEY": "${SUPERMEMORY_API_KEY}"
      }
    }
  }
}