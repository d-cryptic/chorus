# Chorus box config. Copy to box/.env (git-ignored) and fill in. Load before running scripts:
#   set -a; source box/.env; set +a

# --- the Worker (queue store) ---
INGEST_URL=https://chorus-app.barundebnath.com
INGEST_TOKEN=              # same value you set via `wrangler secret put INGEST_TOKEN`

# --- LLM ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat
# Optional: draft via the local Hermes agent with a Claude/Codex SUBSCRIPTION ($0 marginal)
# instead of per-token OpenRouter. Format: hermes:<provider>:<model>. Unset -> OpenRouter.
# ACTIVATE (two steps, on the box):
#   1. hermes auth add anthropic        # interactive OAuth with your Claude subscription
#   2. set the line below, then the crons pick it up on the next run
# A measured bake-off picked Claude Sonnet (clean + sharper than deepseek under full context).
# CHORUS_DRAFT_PROVIDER=hermes:anthropic:claude-sonnet-4.6

# --- reads (candidates) — X read adapter is READ-ONLY (Chorus never posts) ---
CANDIDATE_API_KEY=
CHORUS_HANDLE=            # your @ (no @)
CHORUS_TARGETS_A=         # csv of tier-A handles to watch, e.g. dankoe,thisiskp_
CHORUS_TARGETS_B=         # csv of tier-B handles
CHORUS_PILLARS=           # csv (or run onboard.py to infer from your history)
CHORUS_VOICE=concise, specific, no hype

# --- research (swappable) ---
RESEARCH_PROVIDER=linkup  # linkup | firecrawl
LINKUP_API_KEY=
# FIRECRAWL_API_KEY=

# --- memory: self-hosted Supermemory on the box ---
SUPERMEMORY_BASE_URL=http://localhost:8000
# SUPERMEMORY_API_KEY=    # only if your self-host requires a key

# --- notify (swappable) — DEFERRED for v1 (console) ---
NOTIFY_PROVIDER=console   # telegram | discord | whatsapp | console
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# DISCORD_WEBHOOK_URL=
# WHATSAPP_WEBHOOK_URL=
